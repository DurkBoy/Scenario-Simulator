package com.scenariosimulator.domain.engine

import com.scenariosimulator.domain.model.Experiment
import com.scenariosimulator.domain.model.ExperimentStatus
import com.scenariosimulator.domain.model.Message
import com.scenariosimulator.domain.model.MessageType
import com.scenariosimulator.domain.model.Persona
import com.scenariosimulator.domain.model.SummaryResult
import com.scenariosimulator.domain.repository.ExperimentRepository
import com.scenariosimulator.domain.repository.PersonaRepository
import com.scenariosimulator.domain.service.AIServiceManager
import kotlinx.coroutines.CoroutineScope
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.update
import kotlinx.coroutines.launch
import javax.inject.Inject
import javax.inject.Singleton

@Singleton
class SimulationEngine @Inject constructor(
    private val aiServiceManager: AIServiceManager,
    private val experimentRepository: ExperimentRepository,
    private val personaRepository: PersonaRepository
) {

    private val _simulationState = MutableStateFlow(SimulationState())
    val simulationState: StateFlow<SimulationState> = _simulationState.asStateFlow()

    private var currentExperiment: Experiment? = null
    private var currentPersonas: Map<String, Persona> = emptyMap()
    private var currentRound = 0
    private var currentPersonaIndex = 0
    private var isRunning = false
    private var job: kotlinx.coroutines.Job? = null

    data class SimulationState(
        val currentRound: Int = 0,
        val activePersonaId: String? = null,
        val isPaused: Boolean = false,
        val isComplete: Boolean = false,
        val consensusScore: Float = 0f,
        val tensionScore: Float = 0f,
        val messages: List<Message> = emptyList(),
        val experimentId: String? = null
    )

    fun startSimulation(experiment: Experiment) {
        if (isRunning) return
        currentExperiment = experiment
        currentRound = 0
        currentPersonaIndex = 0
        isRunning = true
        _simulationState.update {
            it.copy(
                experimentId = experiment.id,
                currentRound = 0,
                activePersonaId = null,
                isPaused = false,
                isComplete = false,
                messages = emptyList()
            )
        }
        // Load personas
        CoroutineScope(Dispatchers.IO).launch {
            val personas = experiment.participantIds.mapNotNull { id ->
                personaRepository.getPersonaByIdSync(id)
            }.associateBy { it.id }
            currentPersonas = personas
            runNextTurn()
        }
    }

    fun pauseSimulation() {
        _simulationState.update { it.copy(isPaused = true) }
    }

    fun resumeSimulation() {
        _simulationState.update { it.copy(isPaused = false) }
        runNextTurn()
    }

    fun stopSimulation() {
        isRunning = false
        job?.cancel()
        _simulationState.update { it.copy(isComplete = true, activePersonaId = null) }
        persistExperiment()
    }

    fun injectPrompt(newPrompt: String) {
        // Add a system message with new prompt
        val experiment = currentExperiment ?: return
        val systemMessage = Message(
            experimentId = experiment.id,
            personaId = "system",
            content = "New user prompt: $newPrompt",
            timestamp = System.currentTimeMillis(),
            turnNumber = _simulationState.value.messages.size,
            messageType = MessageType.SYSTEM
        )
        _simulationState.update { state ->
            state.copy(messages = state.messages + systemMessage)
        }
        persistMessages()
        // Continue simulation
        runNextTurn()
    }

    fun forceNextSpeaker() {
        advanceToNextSpeaker()
        runNextTurn()
    }

    fun requestSummary() {
        // Generate summary from current messages and update experiment
        CoroutineScope(Dispatchers.IO).launch {
            val summaryResult = generateStructuredSummary()
            val summaryMessage = createSummaryMessage(summaryResult)
            _simulationState.update { state ->
                state.copy(messages = state.messages + summaryMessage)
            }
            persistMessages()
            // Update experiment with structured summary
            val experiment = currentExperiment
            if (experiment != null) {
                val updatedExperiment = experiment.copy(summary = summaryResult)
                currentExperiment = updatedExperiment
                experimentRepository.saveExperiment(updatedExperiment)
            }
        }
    }

    private suspend fun generateStructuredSummary(): SummaryResult {
        val experiment = currentExperiment ?: throw IllegalStateException("No experiment")
        val history = _simulationState.value.messages
        return aiServiceManager.generateSummary(experiment, history)
    }

    private fun createSummaryMessage(summary: SummaryResult): Message {
        val experiment = currentExperiment!!
        val summaryText = """
            Key Takeaways:
            ${summary.keyTakeaways.joinToString("\n") { "- $it" }}
            
            Major Disagreements:
            ${summary.majorDisagreements.joinToString("\n") { "- $it" }}
            
            Strongest Ideas:
            ${summary.strongestIdeas.joinToString("\n") { "- $it" }}
            
            Action Plan:
            ${summary.actionPlan.joinToString("\n") { "- $it" }}
            
            Consensus:
            ${summary.consensus}
            
            Open Questions:
            ${summary.openQuestions.joinToString("\n") { "- $it" }}
        """.trimIndent()
        return Message(
            experimentId = experiment.id,
            personaId = "summary",
            content = summaryText,
            timestamp = System.currentTimeMillis(),
            turnNumber = _simulationState.value.messages.size,
            messageType = MessageType.SUMMARY
        )
    }

    private fun runNextTurn() {
        if (!isRunning || _simulationState.value.isPaused || _simulationState.value.isComplete) return

        val experiment = currentExperiment ?: return
        val personas = currentPersonas
        if (personas.isEmpty()) return

        if (currentPersonaIndex >= experiment.participantIds.size) {
            // End of round, increment round
            currentPersonaIndex = 0
            currentRound++
            if (currentRound >= experiment.settings.defaultRounds) {
                // Simulation complete
                stopSimulation()
                return
            }
        }

        val currentPersonaId = experiment.participantIds[currentPersonaIndex]
        val currentPersona = personas[currentPersonaId] ?: return

        _simulationState.update { it.copy(activePersonaId = currentPersonaId, currentRound = currentRound) }

        job = CoroutineScope(Dispatchers.IO).launch {
            // Simulate typing delay based on settings
            kotlinx.coroutines.delay(experiment.settings.responseSpeed.toLong())

            val response = aiServiceManager.generateResponse(
                experiment = experiment,
                persona = currentPersona,
                conversationHistory = _simulationState.value.messages,
                userPrompt = experiment.prompt
            )

            val message = Message(
                experimentId = experiment.id,
                personaId = currentPersonaId,
                content = response,
                timestamp = System.currentTimeMillis(),
                turnNumber = _simulationState.value.messages.size,
                messageType = MessageType.REGULAR
            )

            _simulationState.update { state ->
                state.copy(messages = state.messages + message)
            }
            persistMessages()

            advanceToNextSpeaker()
            runNextTurn()
        }
    }

    private fun advanceToNextSpeaker() {
        currentPersonaIndex++
        _simulationState.update { it.copy(activePersonaId = null) }
    }

    private fun persistMessages() {
        val experiment = currentExperiment ?: return
        val updatedExperiment = experiment.copy(transcript = _simulationState.value.messages)
        currentExperiment = updatedExperiment
        CoroutineScope(Dispatchers.IO).launch {
            experimentRepository.saveExperiment(updatedExperiment)
        }
    }

    private fun persistExperiment() {
        val experiment = currentExperiment ?: return
        CoroutineScope(Dispatchers.IO).launch {
            experimentRepository.saveExperiment(experiment)
        }
    }
}
