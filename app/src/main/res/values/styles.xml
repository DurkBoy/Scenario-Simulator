<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget">
        <item name="android:background">@color/ss_surface_alt</item>
    </style>


    <style name="Widget.ScenarioSimulator">
        <item name="android:background">@color/ss_surface_alt</item>
    </style>

    <style name="TextAppearance.ScenarioSimulator" parent="@android:style/TextAppearance.Medium">
        <item name="android:textColor">@color/ss_white</item>
    </style>

    <style name="TextAppearance.ScenarioSimulator.Title" parent="@style/TextAppearance.ScenarioSimulator">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.ScenarioSimulator.Body" parent="@style/TextAppearance.ScenarioSimulator">
        <item name="android:textColor">@color/ss_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.ScenarioSimulator.Card">
        <item name="android:background">@color/ss_surface_alt</item>
    </style>
</resources>
